source "https://rubygems.org"

# Jekyll 3.9.x — latest 3.x line for GitHub Pages compatibility
gem "jekyll", "~> 4.4.1"

# Ruby 4.0+ extracted stdlib gems
gem "csv"
gem "webrick"

# Optional: silences faraday warning
gem "faraday-retry"

# Windows: avoid file polling (Jekyll suggestion)
gem "wdm", ">= 0.1.0", platforms: [:mswin, :mingw, :x64_mingw]

# kramdown v2 with GFM parser support
gem "kramdown", "~> 2.4"
gem "kramdown-parser-gfm", "~> 1.1"

# Plugins used by the site
gem "jekyll-sitemap"
gem "jekyll-feed"
gem "jekyll-gist"
gem "jekyll-mentions"
